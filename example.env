# ==========================================
# sn2md Project Configuration
# ==========================================
# This file contains all possible environment configurations for the sn2md project.
# To use: Copy this file to '.env' and modify the values as needed.

# ==========================================
# 1. Common Settings (All Stacks)
# ==========================================

# User ID and Group ID for file permissions
# These should match your host user (run `id` to check).
# Default: 1000
PUID=1000
PGID=1000

# Timezone
# Default: America/New_York
TZ=America/New_York

# ==========================================
# 2. AI Processing Configuration (sn2md)
# ==========================================

# OpenAI API Key
# Required for transcription and summarization features.
# Leave blank or set to "none" if you are not using AI features.
OPENAI_API_KEY=

# OpenAI Model
# The model to use for processing notes.
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# ==========================================
# 3. WebDAV Stack Configuration (docker-compose.webdav.yml)
# ==========================================

# WebDAV Username
# Default: admin
WEBDAV_USERNAME=admin

# WebDAV Password
# Default: admin
WEBDAV_PASSWORD=admin

# ==========================================
# 4. Supernote Cloud Stack Configuration (docker-compose.sn-cloud.yml)
# ==========================================

# --- Database (MariaDB) ---

# Root password for MariaDB
# Default: MysqlrootPassword
MYSQL_ROOT_PASSWORD=MysqlrootPassword

# Database User
# Default: supernote
MYSQL_USER=supernote

# Database User Password
# Default: supernotedbpassword
MYSQL_PASSWORD=supernotedbpassword

# --- Redis ---

# Redis Password
# Default: supernoteredispassword
REDIS_PASSWORD=supernoteredispassword

# --- Networking & SSL ---

# HTTP Port for Supernote Web Management
# Default: 19072
HOST_HTTP_PORT=19072

# HTTPS Port for Supernote Web Management
# Default: 19443
HOST_HTTPS_PORT=19443

# Domain Name
# Default: supernote.local
DOMAIN_NAME=supernote.local

# SSL Certificate Filename (in ./data/cert)
# Default: server.crt
SSL_CERT_NAME=server.crt

# SSL Key Filename (in ./data/cert)
# Default: server.key
SSL_KEY_NAME=server.key
