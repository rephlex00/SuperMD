# Supernote Private Cloud & sn2md Configuration
# Copy this file to sn-cloud.env and fill in your secrets
# Use with: docker-compose -f docker-compose.sn-cloud.yml --env-file sn-cloud.env up -d

# --- Database Credentials ---
# [Images: mariadb:10.6.24, supernote/supernote-service:latest]
# Password for the root user of MariaDB
# Default: MysqlrootPassword
MYSQL_ROOT_PASSWORD=MysqlrootPassword

# Username for the Supernote database
# Default: supernote
MYSQL_USER=supernote

# Password for the Supernote database user
# Default: supernotedbpassword
MYSQL_PASSWORD=supernotedbpassword

# --- Redis Configuration ---
# [Images: redis:7.4.7, supernote/supernote-service:latest]
# Password for Redis authentication
# Default: supernoteredispassword
REDIS_PASSWORD=supernoteredispassword

# --- Network & Exposure ---
# [Image: supernote/supernote-service:latest]
# Port to expose the Web Management Interface and Sync Service on the host
# Default: 19072
HOST_HTTP_PORT=19072

# Port to expose the HTTPS interface on the host
# Default: 19443
HOST_HTTPS_PORT=19443

# Domain name for the service
# Default: supernote.local
DOMAIN_NAME=supernote.local

# --- SSL Configuration ---
# [Image: supernote/supernote-service:latest]
# Name of the SSL certificate file in ./data/cert
# Default: server.crt
SSL_CERT_NAME=server.crt

# Name of the SSL private key file in ./data/cert
# Default: server.key
SSL_KEY_NAME=server.key

# --- sn2md AI Configuration ---
# [Image: sn2md-app (local build)]
# OpenAI API Key for transcription/summarization
# Required if using OpenAI models. Leave blank if using Ollama locally.
OPENAI_API_KEY=

# Model to use for AI processing
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
