# SuperMD Docker environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── User identity ─────────────────────────────────────────────────────────────
# Match to your host user so output files aren't owned by root.
# Run `id` in your terminal to find your values.
PUID=1000
PGID=1000

# ── API key ───────────────────────────────────────────────────────────────────
# Only one key is required: the one matching the `model` in your supermd.yaml.
#
# Model → required key:
#   gpt-4o-mini / gpt-4o          → OPENAI_API_KEY
#   gemini/gemini-2.5-flash       → GEMINI_API_KEY
#   claude-sonnet-4-6 / haiku-*   → ANTHROPIC_API_KEY

OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIzaSy...
# ANTHROPIC_API_KEY=sk-ant-...
