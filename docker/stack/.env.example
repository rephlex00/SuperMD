# =============================================================================
# SuperMD Full Stack — Environment Configuration
# =============================================================================
# Only non-sensitive settings belong here.  Passwords and API keys go in the
# secrets/ directory as individual files (see README.md).
# =============================================================================

# ── User identity ───────────────────────────────────────────────────────────
# Match to your host user so output files aren't owned by root.
# Run `id` in your terminal to find your UID and GID.
PUID=1000
PGID=1000

# ── LLM Provider ───────────────────────────────────────────────────────────
# Which provider does the API key in secrets/llm_api_key belong to?
# Options: openai | gemini | anthropic
LLM_PROVIDER=openai

# ── Supernote Cloud (only with --profile cloud) ────────────────────────────
# How often to check for new files (seconds).
SYNC_INTERVAL=300
# Remote directory on Supernote Cloud to sync from.
SYNC_PATH=/Note

# ── Obsidian Sync ───────────────────────────────────────────────────────────
# Name of the remote vault on your Obsidian Sync account.
OBSIDIAN_VAULT_NAME=MyVault

# ── Advanced ────────────────────────────────────────────────────────────────
# Override the default SuperMD config by pointing to your own YAML file.
# SUPERMD_CONFIG=./my-custom-config.yaml
